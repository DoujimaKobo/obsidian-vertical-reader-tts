{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "lib": [
      "ES2018",
      "DOM"
    ],
    "moduleResolution": "node",
    "allowJs": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "noEmit": true,
    "strict": true,
    "types": [
      "node"
    ],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*"
  ]
}
