{
  "name": "obsidian-vertical-reader-tts",
  "version": "1.1.0",
  "description": "Obsidian plugin for vertical reading with ruby text and selectable TTS (OS-native / VOICEVOX)",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc --noEmit && node esbuild.config.mjs production",
    "typecheck": "tsc --noEmit",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "tts",
    "vertical",
    "ruby"
  ],
  "author": "DoujimaKobo",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "esbuild-svelte": "^0.8.0",
    "obsidian": "latest",
    "svelte": "^4.2.0",
    "svelte-preprocess": "^5.1.0",
    "tslib": "^2.6.0",
    "typescript": "^5.3.0"
  }
}
